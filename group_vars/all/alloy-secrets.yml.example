# Copy this file to alloy-secrets.yml and encrypt it with Ansible Vault.
# Example:
#   cp group_vars/all/alloy-secrets.yml.example group_vars/all/alloy-secrets.yml
#   ansible-vault encrypt group_vars/all/alloy-secrets.yml
#
# In AWX, configure a Vault credential so the job can decrypt this file.

alloy_prometheus_password: "REPLACE_ME"
alloy_loki_password: "REPLACE_ME"
